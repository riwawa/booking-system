generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantPlan {
  free
  starter
  pro
}

enum UserRole {
  owner
  staff
  customer
}

enum BookingStatus {
  pending
  confirmed
  cancelled
  completed
  no_show
}

enum PaymentGateway {
  mercadopago
  stripe
  pagseguro
}

enum PaymentMethod {
  pix
  credit_card
  boleto
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

enum NotificationChannel {
  whatsapp
  email
  sms
}

enum NotificationType {
  confirmation
  reminder
  cancellation
}

enum NotificationStatus {
  queued
  sent
  delivered
  failed
}

model Tenant {
  id        String     @id @default(uuid())
  name      String
  slug      String     @unique
  timezone  String     @default("America/Sao_Paulo")
  plan      TenantPlan @default(free)
  settings  Json       @default("{}")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  deletedAt DateTime?  @map("deleted_at")
  users     User[]
  providers Provider[]
  services  Service[]
  bookings  Booking[]
  payments  Payment[]
  @@map("tenants")
}

model User {
  id            String    @id @default(uuid())
  tenantId      String    @map("tenant_id")
  name          String
  email         String
  phone         String?
  role          UserRole  @default(customer)
  passwordHash  String    @map("password_hash")
  whatsappOptIn Boolean   @default(false) @map("whatsapp_opt_in")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  bookings      Booking[]
  provider      Provider?
  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

model Provider {
  id             String         @id @default(uuid())
  tenantId       String         @map("tenant_id")
  userId         String?        @unique @map("user_id")
  name           String
  specialty      String?
  bio            String?
  avatarUrl      String?        @map("avatar_url")
  active         Boolean        @default(true)
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  tenant         Tenant         @relation(fields: [tenantId], references: [id])
  user           User?          @relation(fields: [userId], references: [id])
  availabilities Availability[]
  bookings       Booking[]
  @@index([tenantId])
  @@map("providers")
}

model Service {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  name            String
  description     String?
  durationMin     Int       @map("duration_min")
  price           Decimal   @db.Decimal(10, 2)
  currency        String    @default("BRL")
  requiresPayment Boolean   @default(false) @map("requires_payment")
  bufferAfterMin  Int       @default(0) @map("buffer_after_min")
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  bookings        Booking[]
  @@index([tenantId])
  @@map("services")
}

model Availability {
  id         String   @id @default(uuid())
  providerId String   @map("provider_id")
  dayOfWeek  Int      @map("day_of_week")
  startTime  String   @map("start_time")
  endTime    String   @map("end_time")
  active     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  provider   Provider @relation(fields: [providerId], references: [id])
  @@index([providerId])
  @@map("availabilities")
}

model Booking {
  id             String         @id @default(uuid())
  tenantId       String         @map("tenant_id")
  customerId     String         @map("customer_id")
  providerId     String         @map("provider_id")
  serviceId      String         @map("service_id")
  startsAt       DateTime       @map("starts_at")
  endsAt         DateTime       @map("ends_at")
  status         BookingStatus  @default(pending)
  notes          String?
  priceSnapshot  Decimal        @db.Decimal(10, 2) @map("price_snapshot")
  idempotencyKey String         @unique @map("idempotency_key")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  tenant         Tenant         @relation(fields: [tenantId], references: [id])
  customer       User           @relation(fields: [customerId], references: [id])
  provider       Provider       @relation(fields: [providerId], references: [id])
  service        Service        @relation(fields: [serviceId], references: [id])
  payment        Payment?
  notifications  Notification[]
  @@index([tenantId, startsAt])
  @@index([tenantId, providerId, startsAt])
  @@map("bookings")
}

model Payment {
  id               String         @id @default(uuid())
  bookingId        String         @unique @map("booking_id")
  tenantId         String         @map("tenant_id")
  gateway          PaymentGateway
  gatewayPaymentId String?        @map("gateway_payment_id")
  method           PaymentMethod
  amount           Decimal        @db.Decimal(10, 2)
  status           PaymentStatus  @default(pending)
  paidAt           DateTime?      @map("paid_at")
  webhookRaw       Json?          @map("webhook_raw")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  booking          Booking        @relation(fields: [bookingId], references: [id])
  tenant           Tenant         @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([gatewayPaymentId])
  @@map("payments")
}

model Notification {
  id        String              @id @default(uuid())
  bookingId String              @map("booking_id")
  channel   NotificationChannel
  type      NotificationType
  status    NotificationStatus  @default(queued)
  sentAt    DateTime?           @map("sent_at")
  payload   Json?
  createdAt DateTime            @default(now()) @map("created_at")
  booking   Booking             @relation(fields: [bookingId], references: [id])
  @@index([bookingId])
  @@map("notifications")
}